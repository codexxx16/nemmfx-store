# ══════════════════════════════════════════
# NemmFX Store — Environment Variables
# by CharlessDev | charless-dev.vercel.app
# ══════════════════════════════════════════

# ── REQUIRED (app won't work without these) ──
NEXTAUTH_SECRET=any-random-string-here
NEXTAUTH_URL=https://your-vercel-url.vercel.app

# ── SUPABASE (required for orders/users) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── PAYPAL (required for PayPal payments) ──
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ── OPTIONAL AUTH PROVIDERS ──
# Leave empty to disable — guest login always works
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── OPTIONAL NOTIFICATIONS ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
RESEND_API_KEY=

# ── APP ──
NEXT_PUBLIC_APP_URL=https://your-vercel-url.vercel.app
DEVELOPER_WHATSAPP=+27642701608
